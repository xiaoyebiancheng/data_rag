# Runtime
PROJECT_ROOT=/app
PYTHONPATH=/app

# API auth
AUTH_ALLOW_ANONYMOUS=true
AUTH_DEFAULT_VISIBILITY=tenant
AUTH_MOCK_USER_ID=dev-user
AUTH_MOCK_TENANT_ID=default
AUTH_MOCK_DEPARTMENT_ID=default

# LLM / VLM, OpenAI-compatible endpoint
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=replace-me
LLM_DEFAULT_MODEL=qwen3-32b
LLM_DEFAULT_TEMPERATURE=0.1
VL_MODEL=qwen-vl-plus

# MinerU PDF parsing
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_API_TOKEN=replace-me
MINERU_MODEL_SOURCE=modelscope

# Milvus
MILVUS_URL=http://localhost:19530
CHUNKS_COLLECTION=kb_chunks
ITEM_NAME_COLLECTION=kb_item_names
ENTITY_NAME_COLLECTION=kb_entity_names

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=dataset_rag

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=replace-me
MINIO_ROOT_PASSWORD=replace-me
MINIO_ACCESS_KEY=replace-me
MINIO_SECRET_KEY=replace-me
MINIO_BUCKET_NAME=knowledge-base-files
MINIO_IMG_DIR=/upload-images
MINIO_SECURE=False

# Milvus internal object storage, used by docker-compose milvus-minio.
MILVUS_MINIO_ACCESS_KEY=replace-me
MILVUS_MINIO_SECRET_KEY=replace-me

# Embedding / reranker
BGE_M3_PATH=BAAI/bge-m3
BGE_M3=BAAI/bge-m3
BGE_DEVICE=cpu
BGE_FP16=0
BGE_RERANKER_LARGE=BAAI/bge-reranker-large
BGE_RERANKER_DEVICE=cpu
BGE_RERANKER_FP16=0
EMBEDDING_DIM=1024

# Bailian MCP web search
MCP_DASHSCOPE_BASE_URL_STREAMABLE=replace-me

# Logs
LOG_CONSOLE_ENABLE=True
LOG_CONSOLE_LEVEL=INFO
LOG_FILE_ENABLE=True
LOG_FILE_LEVEL=INFO
LOG_FILE_RETENTION=7 days
